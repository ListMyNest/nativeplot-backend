# Production build — copy to .env.production locally or set in Vercel / hosting dashboard.
# Never commit real URLs with secrets.

# Public API base (must include /v1). Example:
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/v1
NEXT_PUBLIC_API_BASE_URL=

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Site contact / enquiry (optional)
NEXT_PUBLIC_ENQUIRY_PHONE=
NEXT_PUBLIC_FALLBACK_BUYER_CONTACT_PHONE=

# Firebase Web (phone auth) — use production Firebase project for prod
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
