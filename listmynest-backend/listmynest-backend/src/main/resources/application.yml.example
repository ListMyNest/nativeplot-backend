# Copy to application.yml or set equivalent environment variables (see README).
# Never commit real secrets.

server:
  port: ${SERVER_PORT:8080}
  shutdown: graceful
  # When behind Nginx/Caddy, trust X-Forwarded-* for client IP (used by IP rate limits).
  forward-headers-strategy: ${SERVER_FORWARD_HEADERS_STRATEGY:framework}
  tomcat:
    threads:
      max: ${TOMCAT_MAX_THREADS:200}
      min-spare: ${TOMCAT_MIN_SPARE_THREADS:10}
    accept-count: ${TOMCAT_ACCEPT_COUNT:100}
    max-connections: ${TOMCAT_MAX_CONNECTIONS:8000}

spring:
  lifecycle:
    timeout-per-shutdown-phase: ${SPRING_LIFECYCLE_SHUTDOWN_TIMEOUT:30s}
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://YOUR_DB_HOST:5432/postgres?sslmode=require}
    username: ${SPRING_DATASOURCE_USERNAME:postgres.YOUR_PROJECT_REF}
    password: ${SPRING_DATASOURCE_PASSWORD:YOUR_SUPABASE_DB_PASSWORD}
    driver-class-name: org.postgresql.Driver
    hikari:
      pool-name: listmynest-pg
      maximum-pool-size: ${HIKARI_MAXIMUM_POOL_SIZE:20}
      minimum-idle: ${HIKARI_MINIMUM_IDLE:5}
      connection-timeout: ${HIKARI_CONNECTION_TIMEOUT_MS:20000}
      idle-timeout: ${HIKARI_IDLE_TIMEOUT_MS:600000}
      max-lifetime: ${HIKARI_MAX_LIFETIME_MS:1800000}
  jpa:
    hibernate:
      ddl-auto: validate
    properties:
      hibernate:
        dialect: org.hibernate.dialect.PostgreSQLDialect
    show-sql: false
  flyway:
    enabled: true
    locations: classpath:db/migration
  data:
    redis:
      url: ${SPRING_DATA_REDIS_URL:redis://default:YOUR_UPSTASH_TOKEN@YOUR_UPSTASH_HOST:6379}

jwt:
  secret: ${JWT_SECRET:YOUR_JWT_SECRET_MIN_32_CHARS}
  expiry-hours: ${JWT_EXPIRY_HOURS:24}
  admin-expiry-hours: ${ADMIN_JWT_EXPIRY_HOURS:8}

msg91:
  auth-key: ${MSG91_AUTH_KEY:}
  sender-id: ${MSG91_SENDER_ID:LSTNEST}

supabase:
  url: ${SUPABASE_URL:https://YOUR_PROJECT_REF.supabase.co}
  service-key: ${SUPABASE_SERVICE_KEY:YOUR_SUPABASE_SERVICE_ROLE_KEY}
  storage-bucket: ${SUPABASE_STORAGE_BUCKET:property-photos}

google:
  maps:
    api-key: ${GOOGLE_MAPS_API_KEY:}

firebase:
  service-account-json: ${FIREBASE_SERVICE_ACCOUNT_JSON:{}}

wati:
  api-token: ${WATI_API_TOKEN:}
  base-url: ${WATI_BASE_URL:https://live-server.wati.io}
  webhook-secret: ${WATI_WEBHOOK_SECRET:}

# Comma-separated browser origins. Production: https://www.yourdomain.com,https://yourdomain.com
cors:
  allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:3000}

# --- Production profile (see also src/main/resources/application-prod.yml) ---
# Run with: SPRING_PROFILES_ACTIVE=prod
# - Restricts /actuator to health (see SecurityConfig) and hides OpenAPI/Swagger from the internet.
# - Set CORS_ALLOWED_ORIGINS to your real site + optional preview URLs.
# - Set JWT_SECRET to a long random value; never use the example placeholder.

app:
  base-url: ${APP_BASE_URL:http://localhost:8080}
  fallback-buyer-contact-phone: ${FALLBACK_BUYER_CONTACT_PHONE:+919876543210}
  admin-invite-secret: ${ADMIN_INVITE_SECRET:}

# Local profile: set LISTMYNEST_EMBEDDED_POSTGRES=true only if you want an in-memory Postgres (data is lost when the JVM exits).
listmynest:
  embedded:
    postgres: ${LISTMYNEST_EMBEDDED_POSTGRES:false}
  # Redis-backed caches (TTL 0 = disabled). Short TTL on listings reduces DB load; invalidate implicitly via TTL.
  cache:
    public-listings-ttl-seconds: ${LISTMYNEST_CACHE_PUBLIC_LISTINGS_TTL:30}
    geocode-ttl-seconds: ${LISTMYNEST_CACHE_GEOCODE_TTL:604800}
  http:
    client:
      connect-timeout-ms: ${LISTMYNEST_HTTP_CONNECT_TIMEOUT_MS:5000}
      read-timeout-ms: ${LISTMYNEST_HTTP_READ_TIMEOUT_MS:15000}
  auth:
    # Production: MSG91_AUTH_KEY is required unless this is true (password/Firebase-only deployments).
    allow-sms-disabled: ${LISTMYNEST_AUTH_ALLOW_SMS_DISABLED:false}
  rate-limit:
    ip:
      # Master switch for {@link com.listmynest.config.PublicWriteIpRateLimitFilter}.
      enabled: ${LISTMYNEST_RATE_LIMIT_IP_ENABLED:true}
      # When false, Redis failures cause 429 instead of allowing traffic (set false in prod).
      fail-open-on-redis-miss: ${LISTMYNEST_RL_IP_FAIL_OPEN:true}
      post-leads-per-hour: ${LISTMYNEST_RL_IP_LEADS_PER_HOUR:200}
      post-visits-per-hour: ${LISTMYNEST_RL_IP_VISITS_PER_HOUR:120}
      post-notify-me-per-hour: ${LISTMYNEST_RL_IP_NOTIFY_PER_HOUR:40}
      admin-login-per-15m: ${LISTMYNEST_RL_IP_ADMIN_LOGIN_PER_15M:40}
      admin-register-per-hour: ${LISTMYNEST_RL_IP_ADMIN_REG_PER_HOUR:20}
      otp-send-per-hour: ${LISTMYNEST_RL_IP_OTP_SEND_PER_HOUR:40}
      password-login-per-hour: ${LISTMYNEST_RL_IP_PASSWORD_LOGIN_PER_HOUR:80}
