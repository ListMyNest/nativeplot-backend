# ListMyNest Backend — Environment Variables
# Copy this file to .env (or set in Railway/Render dashboard)
# NEVER commit real values to git

# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:{password}@db.{project-ref}.supabase.co:5432/postgres

# ── Redis (Upstash) ────────────────────────────────────────────────────────────
REDIS_URL=rediss://:{password}@{host}.upstash.io:6380

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-minimum-32-characters-long
JWT_EXPIRY_HOURS=24
ADMIN_JWT_EXPIRY_HOURS=8

# ── MSG91 (OTP / SMS) ──────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=LSTNEST
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MINUTES=5

# ── Supabase Storage ───────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=property-photos

# ── Google Maps ────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-server-key
# Required: Geocoding API (server-side address → lat/lng)

# ── Firebase FCM ───────────────────────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Paste the full JSON as a single line

# ── Wati.io (WhatsApp) ─────────────────────────────────────────────────────────
WATI_API_TOKEN=your-wati-api-token
WATI_BASE_URL=https://live-server.wati.io
WATI_WEBHOOK_SECRET=your-wati-webhook-secret
# Webhook URL to register in Wati: https://api.listmynest.in/v1/leads/whatsapp-inbound

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://listmynest.in,https://www.listmynest.in
# Local dev: CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── App ────────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://api.listmynest.in
SERVER_PORT=8080
