# Monorepo root — keep secrets and machine-local files out of Git

# Repo root: do not track a second npm tree here (run npm in listmynest-frontend/listmynest-frontend).
# If you already ran `npm install` at the monorepo root, these folders must never be committed.
/package.json
/package-lock.json
/node_modules/

# Dependencies & build outputs (never commit)
node_modules/
**/node_modules/
.next/
**/.next/
out/
dist/
**/.gradle/
**/build/
*.tsbuildinfo

# Secrets (Gradle bootRun loads ListMyNest/.env — never commit it)
.env
.env.local
.env.production
.env.*.local

# Keep the template
!.env.example

# OS / IDE
.DS_Store
Thumbs.db
.idea/
*.iml

# Optional local notes
*.pem
